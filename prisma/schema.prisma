generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum UserStatus {
  PENDING
  VERIFIED
}

enum OtpType {
  REGISTRATION
  RESET
}

enum KycDocumentType {
  NATIONAL_ID
  PASSPORT
}

enum KycStatus {
  SUBMITTED
  APPROVED
  REJECTED
}

enum LoanStatus {
  PENDING
  ACTIVE
  CLOSED
  REJECTED
}

model User {
  id           String     @id @default(uuid())
  firstName    String
  lastName     String
  email        String     @unique
  phone        String     @unique
  passwordHash String
  role         Role       @default(USER)
  status       UserStatus @default(PENDING)
  refreshToken String?

  otpRecords      OtpRecord[]
  kycSubmissions  KycSubmission[] @relation("UserKycSubmissions")
  reviewedKyc     KycSubmission[] @relation("ReviewedKycByAdmin")
  loans           Loan[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([status])
  @@index([createdAt])
  @@map("users")
}

model OtpRecord {
  id        String   @id @default(uuid())
  userId    String
  otpHash   String
  expiresAt DateTime
  attempts  Int      @default(0)
  verified  Boolean  @default(false)
  type      OtpType

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, type])
  @@index([userId, type, verified])
  @@index([expiresAt])
  @@index([expiresAt, verified])
  @@map("otp_records")
}

model KycSubmission {
  id            String          @id @default(uuid())
  userId        String
  documentType  KycDocumentType
  frontFilePath String
  backFilePath  String?
  status        KycStatus       @default(SUBMITTED)
  reviewedBy    String?
  rejectionNote String?

  user     User  @relation("UserKycSubmissions", fields: [userId], references: [id], onDelete: Cascade)
  reviewer User? @relation("ReviewedKycByAdmin", fields: [reviewedBy], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, status])
  @@index([status])
  @@index([status, createdAt])
  @@index([reviewedBy])
  @@map("kyc_submissions")
}

model Loan {
  id          String     @id @default(uuid())
  userId      String
  principal   Decimal    @db.Decimal(15, 2)
  annualRate  Decimal?   @db.Decimal(5, 4)
  termMonths  Int
  status      LoanStatus @default(PENDING)
  disbursedAt DateTime?
  purpose     String?

  user        User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  schedule    AmortizationSchedule[]
  interestLog InterestLedger[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, status])
  @@index([status])
  @@index([status, createdAt])
  @@index([disbursedAt])
  @@map("loans")
}

model AmortizationSchedule {
  id            String   @id @default(uuid())
  loanId        String
  installmentNo Int
  dueDate       DateTime @db.Date
  principalDue  Decimal  @db.Decimal(15, 2)
  interestDue   Decimal  @db.Decimal(15, 2)
  totalDue      Decimal  @db.Decimal(15, 2)
  paid          Boolean  @default(false)

  loan Loan @relation(fields: [loanId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([loanId, installmentNo])
  @@index([loanId])
  @@index([loanId, dueDate])
  @@index([loanId, paid, dueDate])
  @@map("amortization_schedule")
}

model InterestLedger {
  id              String   @id @default(uuid())
  loanId          String
  date            DateTime @db.Date
  dailyInterest   Decimal  @db.Decimal(15, 6)
  balanceSnapshot Decimal  @db.Decimal(15, 2)

  loan Loan @relation(fields: [loanId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([loanId, date])
  @@index([date])
  @@index([loanId, date])
  @@map("interest_ledger")
}
