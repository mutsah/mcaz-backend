generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum UserStatus {
  PENDING
  VERIFIED
}

enum OtpType {
  REGISTRATION
  RESET
}

enum DosageForm {
  INJECTION
  ORAL
  EXTERNAL
  VAGINAL
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id           String     @id @default(uuid())
  firstName    String
  lastName     String
  email        String     @unique
  phone        String     @unique
  passwordHash String
  role         Role       @default(USER)
  status       UserStatus @default(PENDING)
  refreshToken String?

  otpRecords         OtpRecord[]
  capturedDrugs      Drug[]             @relation("DrugCapturedBy")
  approvedDrugs      Drug[]             @relation("DrugApprovedBy")
  drugStatusHistory  DrugStatusHistory[] @relation("StatusHistoryActor")
  auditLogs          AuditLog[]         @relation("AuditActor")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([status])
  @@index([createdAt])
  @@map("users")
}

model OtpRecord {
  id        String   @id @default(uuid())
  userId    String
  otpHash   String
  expiresAt DateTime
  attempts  Int      @default(0)
  verified  Boolean  @default(false)
  type      OtpType

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, type])
  @@index([userId, type, verified])
  @@index([expiresAt])
  @@index([expiresAt, verified])
  @@map("otp_records")
}

model Drug {
  id                 String            @id @default(uuid())
  genericName        String
  strength           String
  dosageForm         DosageForm
  registrationNumber String            @unique
  countryOfOrigin    String
  status             ApplicationStatus @default(PENDING)
  capturedBy         String
  approvedBy         String?
  dateCaptured       DateTime          @default(now())
  dateApproved       DateTime?
  expiryDate         DateTime

  capturer      User                @relation("DrugCapturedBy", fields: [capturedBy], references: [id])
  approver      User?               @relation("DrugApprovedBy", fields: [approvedBy], references: [id])
  statusHistory DrugStatusHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([status, createdAt])
  @@index([registrationNumber])
  @@index([dateCaptured])
  @@map("drugs")
}

model DrugStatusHistory {
  id        String            @id @default(uuid())
  drugId    String
  status    ApplicationStatus
  changedBy String?
  note      String?

  drug  Drug  @relation(fields: [drugId], references: [id], onDelete: Cascade)
  actor User? @relation("StatusHistoryActor", fields: [changedBy], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([drugId])
  @@index([drugId, createdAt])
  @@index([changedBy])
  @@index([createdAt])
  @@map("drug_status_history")
}

model AuditLog {
  id             String   @id @default(uuid())
  actorId        String?
  action         String
  method         String
  path           String
  statusCode     Int
  responseTimeMs Int
  ipAddress      String?
  userAgent      String?
  metadata       Json?

  actor User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([method])
  @@index([statusCode])
  @@index([createdAt])
  @@index([method, createdAt])
  @@index([actorId, createdAt])
  @@map("audit_logs")
}
